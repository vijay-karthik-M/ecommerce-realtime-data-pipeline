
services:
  postgres-airflow:
    image: postgres:13
    environment:
      POSTGRES_USER: airflow
      POSTGRES_PASSWORD: airflow
      POSTGRES_DB: airflow
    ports:
      - "5433:5432"
    volumes:
      - airflow-db:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "airflow"]
      interval: 5s
      retries: 5

  airflow-webserver:
    image: apache/airflow:3.1.8
    depends_on:
      postgres-airflow:
        condition: service_healthy
    environment:
      AIRFLOW__CORE__EXECUTOR: LocalExecutor
      AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql+psycopg2://airflow:airflow@postgres-airflow/airflow
      AIRFLOW__CORE__LOAD_EXAMPLES: 'false'
      AIRFLOW__CORE__RBAC: 'false'
      AIRFLOW__WEBSERVER__AUTHENTICATE: 'false'
      AIRFLOW__API__AUTH_BACKENDS: 'airflow.api.auth.backend.public_user'
    ports:
      - "8080:8080"
    volumes:
      - ./dags:/opt/airflow/dags
      - ./logs:/opt/airflow/logs
      - ./plugins:/opt/airflow/plugins
      - ./init-airflow-user.py:/opt/airflow/init-airflow-user.py
      - ../:/home/jay/data-engineering-projects/ecommerce-streaming-platform-uv
    healthcheck:
      test: ["CMD", "curl", "-s", "http://localhost:8080/api/v1/dags"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s
    command: >
      bash -c "airflow db migrate &&
               airflow api-server"

  airflow-scheduler:
    image: apache/airflow:3.1.8
    depends_on:
      airflow-webserver:
        condition: service_healthy
    environment:
      AIRFLOW__CORE__EXECUTOR: LocalExecutor
      AIRFLOW__DATABASE__SQL_ALCHEMY_CONN: postgresql+psycopg2://airflow:airflow@postgres-airflow/airflow
      AIRFLOW__CORE__LOAD_EXAMPLES: 'false'
      AIRFLOW__CORE__RBAC: 'false'
      AIRFLOW__WEBSERVER__AUTHENTICATE: 'false'
    volumes:
      - ./dags:/opt/airflow/dags
      - ./logs:/opt/airflow/logs
      - ./plugins:/opt/airflow/plugins
      - ../:/home/jay/data-engineering-projects/ecommerce-streaming-platform-uv
    command: scheduler

volumes:
  airflow-db:
